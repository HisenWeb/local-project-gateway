# Copy this file to .env.local and fill local-only values.
# Do not commit .env.local.

# Readonly gateway
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3333

# HTTP MCP server
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3334
MCP_PATH=/mcp
LOCAL_PROJECT_GATEWAY_URL=http://127.0.0.1:3333

# Public Cloudflare Tunnel URL
# Put your real public domain in .env.local, not in this example file.
MCP_PUBLIC_BASE_URL=https://mcp.example.com
# Optional override. Defaults to MCP_PUBLIC_BASE_URL + MCP_PATH.
# MCP_RESOURCE_URL=https://mcp.example.com/mcp
# Optional override. Defaults to MCP_PUBLIC_BASE_URL.
# OAUTH_ISSUER=https://mcp.example.com

# Optional Cloudflare Tunnel startup.
# npm start only starts local gateway + MCP HTTP.
# npm run start:public starts local gateway + MCP HTTP + cloudflared.
CLOUDFLARED_EXE=D:\\cloudflared\\cloudflared.exe
CLOUDFLARED_LOG=D:\\cloudflared\\cloudflared.log
# Prefer your tunnel UUID to avoid name drift.
# Put your real tunnel UUID/name in .env.local, not in this example file.
CLOUDFLARED_TUNNEL=replace-with-your-tunnel-uuid-or-name
# Set to 1 only if you want npm start to also start cloudflared.
# Otherwise use npm run start:public when public tunnel is needed.
START_CLOUDFLARED=0

# OAuth is enabled by default. Set to 0 only for local debugging.
OAUTH_ENABLED=1
OAUTH_DEFAULT_SCOPE=projects:read
# Use a long random local-only approval key.
OAUTH_APPROVE_KEY=replace-with-local-random-approval-key
OAUTH_CLIENTS_FILE=oauth-clients.local.json

# Optional static bearer token for local smoke/debug only.
# Prefer OAuth/DCR for ChatGPT custom MCP connection.
# MCP_BEARER_TOKEN=replace-with-local-random-token
# MCP_STATIC_BEARER_TOKEN=replace-with-local-random-token

# Optional redirect origins. Defaults include ChatGPT and loopback origins.
# OAUTH_ALLOWED_REDIRECT_ORIGINS=https://chatgpt.com https://chat.openai.com

# Local project config.
# By default server.js uses projects.local.json when present, otherwise projects.example.json.
# PROJECTS_CONFIG=D:\\local-project-gateway\\projects.local.json

# Readonly file/image limits
MAX_IMAGE_BYTES=10485760

# run_op readonly diagnostic limits
RUN_OP_TIMEOUT_MS=60000
RUN_OP_MAX_OUTPUT_BYTES=262144
